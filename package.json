{
  "name": "utchess",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build:content": "node scripts/build-content.mjs",
    "cms:seed": "node scripts/seed-content.mjs",
    "cms:server": "npx decap-server",
    "dev": "npm run build:content && vite",
    "dev:cms": "npm run build:content && npx decap-server & vite",
    "build": "npm run build:content && tsc --noEmit && vite build",
    "build:pages": "npm run build:content && tsc --noEmit && GITHUB_PAGES=true vite build && cp dist/index.html dist/404.html",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "decap-server": "^3.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.2",
    "vite": "^6.0.5"
  }
}
